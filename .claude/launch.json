{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source venv/bin/activate && uvicorn app.main:app --reload --port 8000"],
      "port": 8000,
      "cwd": "backend"
    }
  ]
}
