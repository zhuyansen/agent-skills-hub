# GitHub personal access token (required for sync)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local SQLite database (default for development)
DATABASE_URL=sqlite:///./skills_hub.db

# Supabase Transaction Pooler URL (production — uses PgBouncer)
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres

# Supabase Service Role Key (for admin / RLS bypass)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# How often the scheduler triggers a sync (hours)
SYNC_INTERVAL_HOURS=8

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin API token
ADMIN_TOKEN=change-me-to-a-random-secret

# Email — Resend (recommended, free 3000 emails/month)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Agent Skills Hub <noreply@yourdomain.com>
# SITE_URL=https://agentskillshub.top

# Email — BillionMail (alternative)
# BILLIONMAIL_API_URL=https://mail.yourdomain.com
# BILLIONMAIL_API_KEY=your-api-key
